
RewriteOptions inherit
RewriteEngine On

# Allow direct access to existing files & folders (CSS, JS, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Remove .html extension from URLs (single segment: /page)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)$ $1.html [L]

# Remove .html extension from URLs (two segments: /folder/page)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+/[^/]+)$ $1.html [L]

# Redirect all invalid URLs to 404
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . ./404.html [L]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
RewriteCond %{HTTP_HOST} ^.*$
RewriteRule ^/?$ "https\:\/\/meet\.google\.com\/yki\-uskh\-ooh" [R=301,L]
